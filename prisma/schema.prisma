// Tandem — task manager schema
// Docs: https://pris.ly/d/prisma-schema
// NOTE: SQLite has no native enums, so role/type fields are stored as String.
// Allowed values are documented next to each field.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Users & access ────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  username     String    @unique // login, e.g. "v.smolin"
  lastName     String // Фамилия
  firstName    String // Имя
  middleName   String? // Отчество
  birthDate    DateTime? // дата рождения
  email        String?   @unique
  passwordHash String
  role         String    @default("USER") // ADMIN | USER
  avatar       String? // загруженная картинка (url)
  avatarEmoji  String? // эмодзи вместо аватара
  lastSeenAt   DateTime? // онлайн-присутствие
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedBoards        Board[]          @relation("BoardOwner")
  memberships        BoardMember[]
  createdTasks       Task[]           @relation("TaskCreator")
  assignments        TaskAssignee[]
  comments           Comment[]
  messages           Message[]
  channels           ChannelMember[]
  channelReads       ChannelRead[]
  notifications      Notification[]
  taskHistory        TaskHistory[]
  timeEntries        TimeEntry[]
  permissionOverrides UserPermission[]
  boardTemplates     BoardTemplate[]
}

// ── Boards ────────────────────────────────────────────────────────

model Board {
  id         String   @id @default(cuid())
  title      String
  color      String?
  isPersonal Boolean  @default(false) // personal board = private to owner
  ownerId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner    User          @relation("BoardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members  BoardMember[]
  columns  Column[]
  tasks    Task[]
  labels   Label[]
  links    TaskLink[]
  channels Channel[]
}

model BoardMember {
  id      String @id @default(cuid())
  boardId String
  userId  String
  role    String @default("EDITOR") // OWNER | EDITOR | VIEWER

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

// ── Columns & tasks ───────────────────────────────────────────────

model Column {
  id        String  @id @default(cuid())
  boardId   String
  title     String
  order     Int     @default(0)
  isSystem  Boolean @default(false) // системная колонка (нельзя удалять/переименовывать)
  systemKey String? // напр. "COMPLETED"

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]
}

model Task {
  id          String    @id @default(cuid())
  boardId     String
  columnId    String
  title       String
  description String?
  order       Int       @default(0)
  color       String?
  priority    String    @default("MEDIUM") // LOW | MEDIUM | URGENT
  canvasX     Float?
  canvasY     Float?
  isPersonal  Boolean   @default(false)
  parentId    String?   // subtasks: null = root task
  // recurrence
  recurFreq     String?
  recurInterval Int      @default(1)
  recurDays     String?
  recurUntil    DateTime?
  startDate   DateTime?
  dueDate     DateTime?
  // deadline notification: last sent date (to avoid spam)
  deadlineNotifiedAt DateTime?
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  board       Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column      Column         @relation(fields: [columnId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("TaskCreator", fields: [createdById], references: [id])
  parent      Task?          @relation("Subtasks", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtasks    Task[]         @relation("Subtasks")
  assignees   TaskAssignee[]
  labels      TaskLabel[]
  comments    Comment[]
  history     TaskHistory[]
  timeEntries TimeEntry[]
  attachments TaskAttachment[]
  linksFrom   TaskLink[]     @relation("LinkSource")
  linksTo     TaskLink[]     @relation("LinkTarget")
}

model TaskAssignee {
  taskId    String
  userId    String
  confirmed Boolean @default(false) // исполнитель подтвердил выполнение

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

// ── Visual links between tasks ────────────────────────────────────

model TaskLink {
  id           String @id @default(cuid())
  boardId      String
  sourceTaskId String
  targetTaskId String
  type         String @default("RELATES") // RELATES | BLOCKS | DEPENDS

  board  Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  source Task  @relation("LinkSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  target Task  @relation("LinkTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId])
}

// ── Labels ────────────────────────────────────────────────────────

model Label {
  id      String @id @default(cuid())
  boardId String
  name    String
  color   String @default("#888888")

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks TaskLabel[]
}

model TaskLabel {
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

// ── Comments (task discussion) ────────────────────────────────────

model Comment {
  id        String    @id @default(cuid())
  taskId    String
  userId    String
  body      String
  editedAt  DateTime?
  createdAt DateTime  @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Messenger ─────────────────────────────────────────────────────

model Channel {
  id        String   @id @default(cuid())
  boardId   String? // null for direct/group channels not tied to a board
  name      String
  type      String   @default("BOARD") // BOARD | DM | GROUP
  createdAt DateTime @default(now())

  board    Board?          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  messages Message[]
  members  ChannelMember[]
  reads    ChannelRead[]
}

model ChannelMember {
  channelId String
  userId    String

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
}

// Tracks when a user last read a channel (for unread counters).
model ChannelRead {
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
}

model Message {
  id        String   @id @default(cuid())
  channelId String
  userId    String
  body      String
  createdAt DateTime @default(now())
  editedAt  DateTime?
  // вложение
  attachmentUrl  String?
  attachmentType String? // image | video | file
  attachmentName String?
  attachmentSize Int?

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Notifications ─────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // mention_comment | mention_message | deadline | task_assigned | task_completed | task_moved
  payload   String   // JSON string
  isRead    Boolean  @default(false)
  link      String?  // navigation URL
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Task history / audit log ──────────────────────────────────────

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  action    String   // created|title|description|column|priority|assignee_add|assignee_remove|due|start|label_add|label_remove|completed|subtask_add|time_logged|attachment_add
  meta      String?  // JSON {before, after, extra}
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

// ── Time tracking ─────────────────────────────────────────────────

model TimeEntry {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  minutes   Int      // продолжительность в минутах
  note      String?
  loggedAt  DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Task file attachments ─────────────────────────────────────────

model TaskAttachment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  url       String
  name      String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// ── Board templates ───────────────────────────────────────────────

model BoardTemplate {
  id          String           @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean          @default(false) // встроенный шаблон
  createdById String
  createdAt   DateTime         @default(now())

  createdBy User             @relation(fields: [createdById], references: [id])
  columns   TemplateColumn[]
}

model TemplateColumn {
  id         String @id @default(cuid())
  templateId String
  title      String
  order      Int
  isSystem   Boolean @default(false)
  systemKey  String?

  template BoardTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ── Granular permissions ──────────────────────────────────────────
// Система прав: роль (USER/ADMIN) → набор разрешений по умолчанию.
// Администратор может переопределить любое право для конкретного пользователя.
//
// Формат perm: "<resource>.<action>[.<scope>]"
// Примеры: "task.delete.any", "board.create", "admin.users.view"

model RolePermission {
  id      String  @id @default(cuid())
  role    String  // USER | ADMIN
  perm    String  // permission key
  granted Boolean @default(true)

  @@unique([role, perm])
}

model UserPermission {
  id      String  @id @default(cuid())
  userId  String
  perm    String
  granted Boolean // true = явно разрешено, false = явно запрещено

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, perm])
}
